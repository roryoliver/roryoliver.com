# Auth.js v5 — required
AUTH_SECRET=
# Generate locally: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"

# Auth.js v5 — Google OAuth (optional, but at least one provider required)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Auth.js v5 — Resend magic-link (optional, but at least one provider required)
AUTH_RESEND_KEY=
AUTH_EMAIL_FROM=auth@roryoliver.com

# Upstash Redis (Vercel Marketplace -> Upstash). Used for Auth.js adapter
# (verification tokens) and for the client config store.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Jira Cloud — server-side only. Never expose with NEXT_PUBLIC_ prefix.
# Token: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_BASE_URL=https://roryoliver.atlassian.net
JIRA_EMAIL=
JIRA_API_TOKEN=
